# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Runtime state — written during demo sessions, must NOT be committed
artifacts/user_state.json
data/online_interactions.jsonl

# Note: artifacts/* and data/*.jsonl USED to be gitignored, but we deliberately
# commit them now so Streamlit Cloud cold-starts in ~10s instead of running the
# 2-3 minute bootstrap pipeline. The trained model and synthetic dataset are
# small (~21 MB total). The bootstrap path in app/streamlit_app.py is kept as
# a fallback for local dev where someone wipes artifacts/ manually.

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

